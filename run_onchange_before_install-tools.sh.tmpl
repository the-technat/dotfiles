#!/bin/sh
# Installs a bunch of tools
# Note: only CLI tools, for desktop tools checkout the store
# Note: pin version if possible (to install on next apply)

{{- if (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") (eq .osid "linux-pop")) }}

###### APT Packages
export DEBIAN_FRONTEND=noninteractive
sudo apt update > /dev/null
sudo apt install tmux vim zsh git gpg gnupg2 gnupg-agent scdaemon pcscd lsb-release unzip -y  > /dev/null

###### Go
VERSION=1.20.4
curl -sSL -o go.tar.gz https://go.dev/dl/go$VERSION.linux-amd64.tar.gz
sudo rm -rf /usr/local/go
sudo tar -C /usr/local -xzf go.tar.gz
rm go.tar.gz

###### Argo CLI
curl -sSL -o argocd-linux-amd64 https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64 > /dev/null
sudo install -m 555 argocd-linux-amd64 /usr/local/bin/argocd > /dev/null
rm argocd-linux-amd64 > /dev/null

###### K3d
curl -s https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh | bash > /dev/null

####### Cilium
CILIUM_CLI_VERSION=$(curl -s https://raw.githubusercontent.com/cilium/cilium-cli/main/stable.txt)
GOOS=$(/usr/local/go/bin/go env GOOS)
GOARCH=$(/usr/local/go/bin/go env GOARCH)
curl -sL --remote-name-all https://github.com/cilium/cilium-cli/releases/download/${CILIUM_CLI_VERSION}/cilium-${GOOS}-${GOARCH}.tar.gz
sudo tar -C /usr/local/bin -xzvf cilium-${GOOS}-${GOARCH}.tar.gz
rm cilium-${GOOS}-${GOARCH}.tar.gz

###### Telepresence
sudo curl -fL https://app.getambassador.io/download/tel2/linux/amd64/latest/telepresence -o /usr/local/bin/telepresence
sudo chmod a+x /usr/local/bin/telepresence

###### Hubble
HUBBLE_CLI_VERSION=$(curl -s https://raw.githubusercontent.com/cilium/hubble/master/stable.txt)
GOOS=$(/usr/local/go/bin/go env GOOS)
GOARCH=$(/usr/local/go/bin/go env GOARCH)
curl -sL --remote-name-all https://github.com/cilium/hubble/releases/download/${HUBBLE_CLI_VERSION}/hubble-${GOOS}-${GOARCH}.tar.gz
sudo tar -C /usr/local/bin -xzvf hubble-${GOOS}-${GOARCH}.tar.gz
rm hubble-${GOOS}-${GOARCH}.tar.gz

###### Docker
curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg > /dev/null
echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu \
  $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
sudo apt-get update > /dev/null
sudo apt-get install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin -y > /dev/null
sudo usermod -aG docker {{ .username }} > /dev/null

###### Kubectl
curl -LO "https://dl.k8s.io/release/v1.17.1/bin/linux/amd64/kubectl" > /dev/null
sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl > /dev/null
rm kubectl

###### Kind
go install sigs.k8s.io/kind@latest

###### Terraform
curl -Lo ./terraform.zip https://releases.hashicorp.com/terraform/1.4.6/terraform_1.4.6_linux_amd64.zip > /dev/null
unzip terraform.zip > /dev/null
sudo install -o root -g root -m 0755 terraform /usr/local/bin/terraform > /dev/null
rm terraform terraform.zip

###### Terraform docs
curl -Lo ./terraform-docs.tar.gz https://github.com/terraform-docs/terraform-docs/releases/download/v0.16.0/terraform-docs-v0.16.0-linux-amd64.tar.gz > /dev/null
tar -xzf terraform-docs.tar.gz  > /dev/null
sudo install -o root -g root -m 0755 terraform-docs /usr/local/bin/terraform-docs > /dev/null
rm terraform-docs terraform-docs.tar.gz

###### Helm
curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/master/scripts/get-helm-3 > /dev/null
chmod 700 get_helm.sh > /dev/null
./get_helm.sh > /dev/null
rm get_helm.sh

###### AWS
curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip"
unzip awscliv2.zip
if ! type "aws" > /dev/null; then
  sudo ./aws/install
else
  sudo ./aws/install --update
fi
rm awscliv2.zip

###### Azure
sudo mkdir -p /etc/apt/keyrings > /dev/null
curl -sLS https://packages.microsoft.com/keys/microsoft.asc |
    gpg --dearmor |
    sudo tee /etc/apt/keyrings/microsoft.gpg > /dev/null
sudo chmod go+r /etc/apt/keyrings/microsoft.gpg > /dev/null
AZ_REPO=$(lsb_release -cs)
echo "deb [arch=`dpkg --print-architecture` signed-by=/etc/apt/keyrings/microsoft.gpg] https://packages.microsoft.com/repos/azure-cli/ $AZ_REPO main" | sudo tee /etc/apt/sources.list.d/azure-cli.list > /dev/null
sudo apt-get update > /dev/null
sudo apt-get install azure-cli -y > /dev/null

###### Kubelogin
VERSION=v0.0.29
curl -Lo kubelogin.zip -L https://github.com/Azure/kubelogin/releases/download/$VERSION/kubelogin-linux-amd64.zip
sudo unzip kubelogin.zip
sudo chmod +x bin/linux-amd64/kubelogin
sudo mv bin/linux-amd64/kubelogin /usr/local/bin
sudo rm -rf bin kubelogin.zip

###### K9s
VERSION=v0.27.3
curl -o k9s.tar.gz -L https://github.com/derailed/k9s/releases/download/$VERSION/k9s_linux_x86_64.tar.gz
tar -zxvf k9s.tar.gz
sudo install -o root -g root -m 0755 k9s /usr/local/bin/k9s
sudo rm README.md LICENSE k9s.tar.gz

###### Tailscale
curl -fsSL https://tailscale.com/install.sh | sh > /dev/null

{{ else }}
  echo "dotfiles currently only work on debian-based systems"
{{- end }}
