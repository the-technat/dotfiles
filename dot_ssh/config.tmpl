AddKeysToAgent  yes
IdentitiesOnly yes

Host github.com 
  User git
  Port 22
  IdentityFile ~/.ssh/id_gh.pub # private key in ssh-agent via icloud automatically

Host i-* mi-*
  ProxyCommand sh -c "aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
  User ec2-user
  ServerAliveInterval 120

Host *
  User technat
