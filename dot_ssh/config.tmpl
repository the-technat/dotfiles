Host infomaniak
  HostName gr1z6.ftp.infomaniak.com
  User gr1z6_technat

Host github.com 
  User git

Host i-* mi-*
  ProxyCommand sh -c "aws ssm start-session --target %h --document-name AWS-StartSSHSession --parameters 'portNumber=%p'"
  User ec2-user
  ServerAliveInterval 120

Host *
  {{- if .use_yubikey }}
  IdentityFile ~/.ssh/id_yubikey
  {{- end }}
