# Defaults
{{ $email := "technat@technat.ch" -}}
{{ $name := "Nathanael Liechti" -}}
{{ $username := "technat" -}}
{{ $signingkey := "22391b207dad6969" -}}
{{ $is_remote := true -}} # helps deciding whether certain apps/configs should be installed or not (only things that are clearly not wanted remotly, otherwise use a regular feature toggle)
{{ $codespaces:= env "CODESPACES" | not | not -}} # some apps need special config if it's a codespace
## Feature toggles
{{ $install_docker := true -}}  

# If TTY we can ask for overrides
{{ if stdinIsATTY -}}
{{   $email = promptStringOnce . "email" "Your email address" "technat@technat.ch" -}}
{{   $name = promptStringOnce . "name" "Your name (git name)" "Nathanael Liechti" -}}
{{   $username = promptStringOnce . "username" "Your username" "technat" -}}
{{   $signingkey = promptStringOnce . "signingkey" "Git signing key" "22391b207dad6969" -}}
{{   $is_remote = promptBoolOnce . "is_remote" "Remote machine?" true -}}
## Feature toggles
{{   $install_docker = promptBoolOnce . "install_docker" "Should docker be installed?" false -}}
{{ end -}}

# If we are running in a codespace, we need to override the user
{{ if $codespaces -}}
{{   $username = "codespace" -}}
{{ end -}}

{{- $osid := .chezmoi.os -}}
{{- if hasKey .chezmoi.osRelease "id" -}}
{{-   $osid = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
{{- end -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}
[data]
  osid = {{ $osid | quote }}
	signingkey = {{ $signingkey | quote }}
  email = {{ $email | quote }}
  username = {{ $username | quote }}
  name = {{ $name | quote }}
  codespaces = {{ $codespaces }}
  is_remote = {{ $is_remote }}

[git]
  autoCommit = true
  autoPush = true
