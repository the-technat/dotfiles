"
" .vimrc File of technat (https://github.com/the-technat/WALl-E)
" Philosohpy: only enabled what you really understand, use as few plugins as possible and as much default settings as possible
"

" General
set encoding=utf-8
set history=1000
set mouse=a
set shell=/usr/bin/zsh
set autoread 

" Behaviour
set confirm
set linebreak
set wrap
set noerrorbells

" UI
set number
set title
set wildmenu
set cursorline
colorscheme torte
syntax enable

" Search
set hlsearch
set ignorecase
set incsearch
set smartcase

" Editor  
set smartindent
set expandtab 
set tabstop=2
set shiftwidth=2
set shiftround
set smarttab
