#!/bin/sh

VERSION=v3.12.0 # Select desired TAG from https://github.com/helm/helm/releases
ARCH={{ .chezmoi.arch }}
OS={{ .chezmoi.os }}

curl -sSL -o /tmp/helm-$OS-$ARCH.tar.gz https://get.helm.sh/helm-$VERSION-$OS-$ARCH.tar.gz 
tar -zxf /tmp/helm-$OS-$ARCH.tar.gz -C /tmp
sudo install -m 555 /tmp/$OS-$ARCH/helm /usr/local/bin/helm
rm /tmp/$OS-$ARCH -rf
