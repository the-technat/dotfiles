#!/bin/sh

VERSION=1.2.463.0 # see https://docs.aws.amazon.com/systems-manager/latest/userguide/session-manager-working-with-install-plugin.html#plugin-version-history

{{- if (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") (eq .osid "linux-pop")) }}
  {{- if eq .chezmoi.arch "arm64" }}
  curl "https://s3.amazonaws.com/session-manager-downloads/plugin/$VERSION/ubuntu_arm64/session-manager-plugin.deb" -o "session-manager-plugin.deb"
  sudo dpkg -i session-manager-plugin.deb
  {{ else }}
  curl "https://s3.amazonaws.com/session-manager-downloads/plugin/$VERSION/ubuntu_64bit/session-manager-plugin.deb" -o "session-manager-plugin.deb"
  sudo dpkg -i session-manager-plugin.deb
  {{- end }}
{{- else if eq .osid "linux-amzn" }}
  {{- if eq .chezmoi.arch "arm64" }}
  sudo yum install -y https://s3.amazonaws.com/session-manager-downloads/plugin/$VERSION/linux_arm64/session-manager-plugin.rpm
  {{ else }}
  sudo yum install -y https://s3.amazonaws.com/session-manager-downloads/plugin/$VERSION/linux_64bit/session-manager-plugin.rpm
  {{- end }}
{{- end }}