#!/bin/sh

{{- if (or (eq .osid "linux-debian") (eq .osid "linux-ubuntu") (eq .osid "linux-pop")) }}

curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg > /dev/null
echo \
  "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu \
  $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
sudo apt-get update > /dev/null
sudo apt-get install docker-ce=5:24.0.2-1~ubuntu.22.04~jammy docker-ce-cli=5:24.0.2-1~ubuntu.22.04~jammy containerd.io=1.6.21-1 docker-buildx-plugin=0.10.5-1~ubuntu.22.04~jammy docker-compose-plugin=2.18.1-1~ubuntu.22.04~jammy -y> /dev/null
sudo usermod -aG docker {{ .username }} > /dev/null

{{ else }}
  echo "docker installation only engineered on Ubuntu based systems"
{{- end }}
